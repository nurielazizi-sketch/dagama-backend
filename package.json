{
  "name": "dagama-backend",
  "version": "1.0.0",
  "description": "DaGama backend on Cloudflare Workers — Trade show intelligence platform",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --env production",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "format": "prettier --write 'src/**/*.ts'",
    "lint": "eslint src/**/*.ts"
  },
  "keywords": [
    "dagama",
    "trade-show",
    "intelligence",
    "telegram",
    "gemini-ai"
  ],
  "author": "DaGama Team",
  "license": "MIT",
  "dependencies": {
    "grammy": "^1.27.0",
    "stripe": "^14.0.0",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "zod": "^3.22.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "wrangler": "^4.83.0",
    "typescript": "^5.3.3",
    "@types/node": "^20.10.6",
    "@cloudflare/workers-types": "^4.20240605.0",
    "prettier": "^3.1.0",
    "eslint": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}