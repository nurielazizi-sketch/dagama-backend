# DaGama Development Environment Variables Template
# 
# Copy this file to .dev.vars and fill in your actual values.
# IMPORTANT: .dev.vars should NEVER be committed to Git

# Telegram Bot - Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_test_telegram_token_here

# Gemini API - Get from https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Google OAuth - Create at https://console.cloud.google.com
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8787/api/auth/google/callback

# Stripe - Get from https://dashboard.stripe.com/apikeys (use TEST keys)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key_here
STRIPE_WEBHOOK_SECRET=whsec_test_your_webhook_secret_here

# Application Config
ENVIRONMENT=development
ORIGIN=http://localhost:8787
WEBHOOK_SECRET=dev_webhook_secret_123456

# WhatsApp Cloud API — leave blank in dev until Meta approval lands.
# When set together, /api/whatsapp/webhook activates and outbound sends work.
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# /admin console allowlist — comma-separated emails. Match is case-insensitive
# and reuses the existing user JWT (no second login). Empty = /admin disabled.
ADMIN_EMAILS=

# Cloudflare Access (Zero Trust) — when both set, /admin requires Google login
# + MFA via the CF Access edge gate AND the Worker re-verifies the
# Cf-Access-Jwt-Assertion header. Leave empty in dev unless you have a tunnel
# set up to /admin via Cloudflare Access.
CF_ACCESS_TEAM_DOMAIN=
CF_ACCESS_AUD_TAG=

# Cloudflare Turnstile — bot mitigation on /register. When both unset,
# /api/auth/register accepts requests without a captcha token (dev fallback).
# For local testing without registering a real site, use Cloudflare's
# always-passes test keys:
#   TURNSTILE_SITE_KEY=1x00000000000000000000AA
#   TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=